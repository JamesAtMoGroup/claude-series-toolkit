# claude-series-toolkit env — 複製成 ~/.claude/secrets/claude-series.env 後填上

# ── Bot knowledge upload endpoint（render 完上傳 vtt + transcript + slides）──
BOT_UPLOAD_URL=https://claude-ai-futurecoach.zeabur.app
BOT_UPLOAD_TOKEN=<向 James 拿 machine_token；admin POST /admin/machine-tokens 生成>

# ── Google Drive 上傳目的地（每集 mp4 + vtt）──
# 一律進 James 的 Drive folder；同事的 rclone gdrive remote 用自己的 Google account
# 但要先請 James share 這個 folder 給你
DRIVE_FOLDER_ID=1ljbamIk9reIFPs3_YqVj1eTn_cNZ194p
DRIVE_FOLDER_NAME_PREFIX=Claude Chat -

# ── iMessage 通知（render 完通知 James）──
# 同事的 Mac 用 iMessage 傳給 James 的手機
IMESSAGE_NOTIFY_NUMBER=0981928525
